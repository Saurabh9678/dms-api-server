              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"OTP sent successfully\",\n  \"data\": {\n    \"message\": \"If the account is valid, an OTP has been sent\",\n    \"requestId\": \"Ab12Cd34\"\n  }\n}"
