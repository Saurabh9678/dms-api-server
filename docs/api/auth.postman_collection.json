          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"9999999999\",\n  \"platform\": \"web\",\n  \"deviceId\": \"browser-1\"\n}"
        },
        "url": {
