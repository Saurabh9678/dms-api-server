      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"...\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        },
        "description": "Auth: Public (refresh token based). Revokes current session."
