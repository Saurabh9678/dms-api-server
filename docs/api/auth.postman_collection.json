      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"message\": \"Token refreshed successfully\",\n  \"data\": {\n    \"accessToken\": \"...\",\n    \"refreshToken\": \"...\",\n    \"expiresIn\": 3600,\n    \"tokenType\": \"Bearer\"\n  }\n}"
        },
        {
          "name": "Invalid Request",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"message\": \"invalid request\"\n}"
        }
