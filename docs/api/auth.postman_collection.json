      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"...\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/refresh-token",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "refresh-token"
          ]
        },
        "description": "Auth: Public (refresh token based). Rotates token pair."
