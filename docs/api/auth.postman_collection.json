    {
      "name": "Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"9999999999\",\n  \"otpCode\": \"123456\",\n  \"platform\": \"web\",\n  \"deviceId\": \"browser-1\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/verify-otp",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "verify-otp"
          ]
        },
        "description": "Auth: Public. Verifies OTP and returns token pair."
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"message\": \"OTP verified successfully\",\n  \"data\": {\n    \"accessToken\": \"...\",\n    \"refreshToken\": \"...\",\n    \"expiresIn\": 3600,\n    \"tokenType\": \"Bearer\"\n  }\n}"
        },
        {
          "name": "Invalid Request",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"message\": \"invalid request\"\n}"
        }
