        {
          "name": "Verify OTP",
          "id": "auth-verify-otp",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"Ab12Cd34\",\n  \"otpCode\": \"123456\"\n}"
