          "name": "Register",
          "id": "auth-register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"9999999999\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Auth: Public. Triggers OTP for user registration/login bootstrap."
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Platform",
                    "value": "web"
                  },
                  {
                    "key": "X-Device-Id",
                    "value": "browser-1"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"9999999999\"\n}"
