{
  "info": {
    "name": "Dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "dashboard",
      "item": [
    {
      "name": "Get Dashboard",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "X-Platform", "value": "web" },
          { "key": "X-Device-Id", "value": "{{device_id}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/dashboard",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "dashboard"],
          "query": [
            { "key": "duration", "value": "1m", "description": "1w | 1m | 3m | 6m | 12m | lifetime (default: lifetime)" },
            { "key": "showroom_id", "value": "", "description": "Optional. Filter by showroom.", "disabled": true }
          ]
        },
        "description": "Protected. Returns dealership health overview: sales performance, inventory state, expense summary, and top vehicle types. Duration filters sales and expenses; inventory reflects current state."
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"message\": \"dashboard data fetched\",\n  \"data\": {\n    \"sales_summary\": {\n      \"vehicles_sold\": 15,\n      \"total_revenue\": 3000000,\n      \"net_profit\": 930000,\n      \"average_profit_per_sale\": 62000\n    },\n    \"inventory_summary\": {\n      \"inventory_count\": 45,\n      \"inventory_value\": 12000000,\n      \"dead_stock_count\": 6,\n      \"average_inventory_age_days\": 38\n    },\n    \"expense_summary\": {\n      \"total_expenses\": 70000,\n      \"average_expense_per_vehicle\": 1555.56\n    },\n    \"top_vehicle_types\": [\n      { \"vehicle_type\": \"car\",   \"vehicles_sold\": 8, \"net_profit\": 500000 },\n      { \"vehicle_type\": \"bike\",  \"vehicles_sold\": 5, \"net_profit\": 300000 },\n      { \"vehicle_type\": \"scooty\", \"vehicles_sold\": 2, \"net_profit\": 130000 }\n    ]\n  }\n}"
        },
        {
          "name": "Invalid Duration",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
        },
        {
          "name": "Invalid Showroom ID",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
        },
        {
          "name": "Unauthorized",
          "status": "Unauthorized",
          "code": 401,
          "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_ACCESS_TOKEN\",\n    \"message\": \"invalid request\"\n  }\n}"
        }
      ]
    }
      ]
    }
  ]
}
