{
  "info": {
    "name": "DMS API - Showroom",
    "_postman_id": "dms-api-showroom-collection",
    "description": "Showroom API endpoints for DMS",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "showroom",
      "item": [
        {
          "name": "Create Showroom",
          "id": "showroom-create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "My Showroom",
                  "type": "text",
                  "description": "Required. Showroom display name."
                },
                {
                  "key": "geolocation",
                  "value": "{\"address\":\"123 Main St\",\"city\":\"Bengaluru\",\"state\":\"Karnataka\",\"pincode\":\"560001\",\"lat\":12.9716,\"lng\":77.5946}",
                  "type": "text",
                  "description": "Optional. JSON string with address, city, state, pincode, lat, lng."
                },
                {
                  "key": "showroom_logo",
                  "type": "file",
                  "description": "Optional. jpg/jpeg/png, max 10 MB.",
                  "disabled": true
                },
                {
                  "key": "showroom_banner",
                  "type": "file",
                  "description": "Optional. jpg/jpeg/png, max 10 MB.",
                  "disabled": true
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/showroom",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "showroom"]
            },
            "description": "Protected. Creates a new showroom and assigns the authenticated user as the owner in a single transaction. Accepts multipart/form-data with optional logo and banner images (jpg/jpeg/png, max 10 MB each). Files are stored locally at {STORAGE_BASE_PATH}/{userID}/{showroomID}/{datetime}.{ext}."
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"showroom created\",\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"My Showroom\",\n    \"showroom_logo\": \"1/1/20240101120000.jpg\",\n    \"showroom_banner\": null,\n    \"geolocation\": {\"address\":\"123 Main St\",\"city\":\"Bengaluru\",\"state\":\"Karnataka\",\"pincode\":\"560001\",\"lat\":12.9716,\"lng\":77.5946}\n  }\n}"
            },
            {
              "name": "Missing Name",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Geolocation JSON",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "File Too Large",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"FILE_TOO_LARGE\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid File Type",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_FILE_TYPE\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Device Context",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_DEVICE_CONTEXT\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_ACCESS_TOKEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Add Showroom Member",
          "id": "showroom-add-member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 42,\n  \"role\": \"employee\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/showroom/:id/member",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "showroom", ":id", "member"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Showroom ID"
                }
              ]
            },
            "description": "Protected. Adds a user as a member of the showroom. Caller must be the showroom owner or manager. Owner can assign role 'manager' or 'employee'. Manager can only assign role 'employee'. Role must be one of: manager, employee."
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"member added\",\n  \"data\": {\n    \"showroom_id\": 1,\n    \"user_id\": 42,\n    \"role\": \"employee\"\n  }\n}"
            },
            {
              "name": "Invalid Body",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Role",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_ACCESS_TOKEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"FORBIDDEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Target User Not Found",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"TARGET_USER_NOT_FOUND\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Already a Member",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"ALREADY_A_MEMBER\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Device Context",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_DEVICE_CONTEXT\",\n    \"message\": \"invalid request\"\n  }\n}"
            }
          ]
        },
        {
          "name": "List Showroom Members",
          "id": "showroom-list-members",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/showroom/:id/member?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "showroom", ":id", "member"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Showroom ID"
                }
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1, min: 1)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Items per page (default: 20, min: 1, max: 100)"
                }
              ]
            },
            "description": "Protected. Lists all members of the showroom. Caller must be the showroom owner or manager. Returns paginated list with user_id, name (null if empty), phone_number (null if empty), and role. Defaults: page=1, limit=20, max limit=100."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"members retrieved\",\n  \"data\": {\n    \"members\": [\n      {\n        \"user_id\": 42,\n        \"name\": \"John Doe\",\n        \"phone_number\": \"+91-9876543210\",\n        \"role\": \"employee\"\n      },\n      {\n        \"user_id\": 7,\n        \"name\": null,\n        \"phone_number\": null,\n        \"role\": \"manager\"\n      }\n    ],\n    \"total\": 2,\n    \"page\": 1,\n    \"limit\": 20\n  }\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_ACCESS_TOKEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"FORBIDDEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Device Context",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_DEVICE_CONTEXT\",\n    \"message\": \"invalid request\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Remove Showroom Member",
          "id": "showroom-remove-member",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/showroom/:id/member/:user_id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "showroom", ":id", "member", ":user_id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Showroom ID"
                },
                {
                  "key": "user_id",
                  "value": "42",
                  "description": "User ID of the member to remove"
                }
              ]
            },
            "description": "Protected. Removes a member from the showroom (soft-delete). Caller must be owner, manager, or the member themselves. Owner can remove any member. Manager can only remove employees. Any member can remove themselves (self-removal). Owner cannot be removed."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"member removed\",\n  \"data\": null\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_ACCESS_TOKEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"FORBIDDEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Member Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"MEMBER_NOT_FOUND\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Showroom ID",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Device Context",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_DEVICE_CONTEXT\",\n    \"message\": \"invalid request\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Member Role",
          "id": "showroom-update-member-role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Platform",
                "value": "web"
              },
              {
                "key": "X-Device-Id",
                "value": "browser-1"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"manager\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/showroom/:id/member/:user_id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "showroom", ":id", "member", ":user_id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Showroom ID"
                },
                {
                  "key": "user_id",
                  "value": "42",
                  "description": "User ID of the member whose role to update"
                }
              ]
            },
            "description": "Protected. Updates the role of a showroom member. Caller must be the showroom owner. Owner cannot change their own role. New role must be one of: manager, employee."
          },
          "response": [
            {
              "name": "OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"member role updated\",\n  \"data\": null\n}"
            },
            {
              "name": "Invalid Body",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Role",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_REQUEST\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_ACCESS_TOKEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Forbidden (not owner or self-role-change)",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"FORBIDDEN\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Member Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"MEMBER_NOT_FOUND\",\n    \"message\": \"invalid request\"\n  }\n}"
            },
            {
              "name": "Invalid Device Context",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"error\": {\n    \"code\": \"INVALID_DEVICE_CONTEXT\",\n    \"message\": \"invalid request\"\n  }\n}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ]
}
